// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ACCOUNTANT
  EMPLOYEE
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
}

model Company {
  id           String   @id @default(uuid())
  name         String
  gstNumber    String?
  baseCurrency String   @default("INR")
  users        User[]
  createdAt    DateTime @default(now())
  invoices     Invoice[]
  expenses     Expense[]
  activityLogs ActivityLog[]
  invites      Invite[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password     String
  role         Role
  permissions  Json?
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())
  expenses     Expense[]
  activityLogs ActivityLog[]
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String
  customerName  String
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(UNPAID)

  subtotal      Float
  totalAmount  Float

  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])

  items         InvoiceItem[]

  templateType  TemplateType  @default(CLASSIC)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum TemplateType {
  CLASSIC
  MODERN
}

model InvoiceItem {
  id          String   @id @default(uuid())
  description String
  quantity    Int
  unitPrice   Float
  total       Float

  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  amount      Float
  category    String
  description String?
  date        DateTime
  companyId   String
  createdBy   String

  company     Company  @relation(fields: [companyId], references: [id])
  user        User     @relation(fields: [createdBy], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
}

enum ActivityEntity {
  INVOICE
  EXPENSE
}

model ActivityLog {
  id        String         @id @default(uuid())
  userId    String
  companyId String
  action    ActivityAction
  entity    ActivityEntity
  entityId  String
  createdAt DateTime       @default(now())

  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Invite {
  id          String       @id @default(uuid())
  email       String
  role        Role
  permissions Json?
  companyId   String
  token       String       @unique
  expiresAt   DateTime
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
}